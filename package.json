{
  "name": "shadcn-vue-ui",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*",
    "shadcn-vue-ui-console",
    "shadcn-vue-ui-business"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:console": "yarn workspace shadcn-vue-ui-console dev",
    "dev:business": "yarn workspace shadcn-vue-ui-business dev",
    "build:console": "yarn workspace shadcn-vue-ui-console build",
    "build:business": "yarn workspace shadcn-vue-ui-business build",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.474.0",
    "reka-ui": "^2.9.2",
    "tailwind-merge": "^3.0.2",
    "vue": "^3.5.30",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.13.2",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "typescript": "~5.8.3"
  }
}
